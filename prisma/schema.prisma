generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String   @id @default(cuid())
  name             String
  email            String   @unique
  passwordHash     String
  role             String   @default("EMPLOYEE") // EMPLOYEE, DEPT_HEAD, ASSET_MANAGER, ADMIN
  status           String   @default("ACTIVE") // ACTIVE, INACTIVE
  departmentId     String?
  department       Department? @relation(name: "UserToDepartment", fields: [departmentId], references: [id])
  createdAt        DateTime @default(now())

  headedDepartments Department[] @relation("DepartmentHead")
  allocationsReceived Allocation[] @relation("AllocationReceiver")
  allocationsMade    Allocation[] @relation("AllocationMaker")
  bookingsMade       Booking[]
  transfersRequested TransferRequest[] @relation("TransferRequester")
  transfersApproved  TransferRequest[] @relation("TransferApprover")
  maintenanceRaised  MaintenanceRequest[] @relation("MaintenanceRaiser")
  maintenanceApproved MaintenanceRequest[] @relation("MaintenanceApprover")
  auditsCreated      AuditCycle[]
  auditItemsVerified AuditItem[]
  notifications      Notification[]
  activityLogs       ActivityLog[]
}

model Department {
  id                 String   @id @default(cuid())
  name               String
  status             String   @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt          DateTime @default(now())
  
  headEmployeeId     String?
  headEmployee       User?    @relation("DepartmentHead", fields: [headEmployeeId], references: [id])
  
  parentDepartmentId String?
  parentDepartment   Department? @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id])
  subDepartments     Department[] @relation("DepartmentHierarchy")

  users              User[]   @relation("UserToDepartment")
  allocationsReceived Allocation[] @relation("AllocationReceiverDept")
}

model AssetCategory {
  id           String   @id @default(cuid())
  name         String
  customFields String?  // JSON serialized schema
  assets       Asset[]
}

model Asset {
  id               String   @id @default(cuid())
  name             String
  categoryId       String
  category         AssetCategory @relation(fields: [categoryId], references: [id])
  assetTag         String   @unique
  serialNumber     String?
  acquisitionDate  DateTime?
  acquisitionCost  Float?
  condition        String   @default("NEW") // NEW, GOOD, FAIR, POOR, DAMAGED
  location         String?
  photoUrls        String?  // JSON array string
  documentUrls     String?  // JSON array string
  isBookable       Boolean  @default(false)
  status           String   @default("AVAILABLE") // AVAILABLE, ALLOCATED, RESERVED, UNDER_MAINTENANCE, LOST, RETIRED, DISPOSED
  qrCodeValue      String?  @unique
  createdAt        DateTime @default(now())

  allocations         Allocation[]
  bookings            Booking[]
  transferRequests    TransferRequest[]
  maintenanceRequests MaintenanceRequest[]
  auditItems          AuditItem[]
}

model Allocation {
  id                   String   @id @default(cuid())
  assetId              String
  asset                Asset    @relation(fields: [assetId], references: [id])
  
  allocatedToType      String   // "EMPLOYEE" or "DEPARTMENT"
  allocatedToUserId    String?
  receiverUser         User?    @relation("AllocationReceiver", fields: [allocatedToUserId], references: [id])
  allocatedToDeptId    String?
  receiverDept         Department? @relation("AllocationReceiverDept", fields: [allocatedToDeptId], references: [id])
  
  allocatedById        String
  allocatedBy          User     @relation("AllocationMaker", fields: [allocatedById], references: [id])
  allocationDate       DateTime @default(now())
  expectedReturnDate   DateTime?
  actualReturnDate     DateTime?
  returnConditionNotes String?
  status               String   @default("ACTIVE") // ACTIVE, RETURNED, OVERDUE
}

model TransferRequest {
  id              String   @id @default(cuid())
  assetId         String
  asset           Asset    @relation(fields: [assetId], references: [id])
  fromHolderId    String   // could be User or Dept, we'll keep it unstructured for simplicity, or we can structure it if needed
  toHolderId      String
  requestedById   String
  requestedBy     User     @relation("TransferRequester", fields: [requestedById], references: [id])
  status          String   @default("REQUESTED") // REQUESTED, APPROVED, REJECTED
  approvedById    String?
  approvedBy      User?    @relation("TransferApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime?
}

model Booking {
  id        String   @id @default(cuid())
  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id])
  bookedById String
  bookedBy  User     @relation(fields: [bookedById], references: [id])
  startTime DateTime
  endTime   DateTime
  status    String   @default("UPCOMING") // UPCOMING, ONGOING, COMPLETED, CANCELLED
  createdAt DateTime @default(now())
}

model MaintenanceRequest {
  id                  String   @id @default(cuid())
  assetId             String
  asset               Asset    @relation(fields: [assetId], references: [id])
  raisedById          String
  raisedBy            User     @relation("MaintenanceRaiser", fields: [raisedById], references: [id])
  issueDescription    String
  priority            String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  photoUrl            String?
  status              String   @default("PENDING") // PENDING, APPROVED, REJECTED, TECHNICIAN_ASSIGNED, IN_PROGRESS, RESOLVED
  assignedTechnician  String?
  approvedById        String?
  approvedBy          User?    @relation("MaintenanceApprover", fields: [approvedById], references: [id])
  resolvedAt          DateTime?
}

model AuditCycle {
  id                 String   @id @default(cuid())
  name               String
  scopeDepartmentId  String?
  scopeLocation      String?
  startDate          DateTime
  endDate            DateTime
  status             String   @default("DRAFT") // DRAFT, ACTIVE, CLOSED
  createdById        String
  createdBy          User     @relation(fields: [createdById], references: [id])
  auditItems         AuditItem[]
}

model AuditItem {
  id           String   @id @default(cuid())
  auditCycleId String
  auditCycle   AuditCycle @relation(fields: [auditCycleId], references: [id])
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id])
  auditorId    String
  auditor      User     @relation(fields: [auditorId], references: [id])
  result       String?  // VERIFIED, MISSING, DAMAGED
  notes        String?
  verifiedAt   DateTime?
}

model Notification {
  id                String   @id @default(cuid())
  recipientId       String
  recipient         User     @relation(fields: [recipientId], references: [id])
  type              String
  message           String
  relatedEntityType String?
  relatedEntityId   String?
  isRead            Boolean  @default(false)
  createdAt         DateTime @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  action     String
  entityType String
  entityId   String
  metadata   String?  // JSON string
  timestamp  DateTime @default(now())
}
